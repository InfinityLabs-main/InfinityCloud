# ═══════════════════════════════════════════════════════
#  Infinity Cloud — переменные окружения
#  Скопируйте в .env и заполните значения
# ═══════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────
POSTGRES_USER=infinity
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=infinity_cloud
DATABASE_URL=postgresql+asyncpg://infinity:CHANGE_ME_STRONG_PASSWORD@postgres:5432/infinity_cloud
DATABASE_URL_SYNC=postgresql://infinity:CHANGE_ME_STRONG_PASSWORD@postgres:5432/infinity_cloud

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── JWT (ОБЯЗАТЕЛЬНО сгенерировать!) ──────────────────
# Генерация: openssl rand -hex 32
SECRET_KEY=GENERATE_ME_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Proxmox VE ───────────────────────────────────────
PROXMOX_HOST=https://proxmox.example.com:8006
PROXMOX_USER=root@pam
PROXMOX_TOKEN_NAME=infinity
PROXMOX_TOKEN_VALUE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_VERIFY_SSL=false

# ── Frontend ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Безопасность ──────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_LOGIN_PER_5MIN=5

# ── Sentry (опционально) ─────────────────────────────
SENTRY_DSN=

# ── Администратор по умолчанию ────────────────────────
ADMIN_EMAIL=admin@infinity.cloud
ADMIN_PASSWORD=Admin123!

# ── YooKassa (Платёжная система) ─────────────────────
# https://yookassa.ru/developers/
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://localhost:3000/dashboard
YOOKASSA_WEBHOOK_SECRET=

# ── Email / SMTP ─────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@infinity.cloud
SMTP_USE_TLS=true

# ── Node Alert Thresholds (%) ────────────────────────
NODE_ALERT_CPU_THRESHOLD=80
NODE_ALERT_RAM_THRESHOLD=80
NODE_ALERT_DISK_THRESHOLD=85

# ── Grafana (логирование) ────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
