# ═══════════════════════════════════════════════════════
#  Infinity Cloud — переменные окружения
# ═══════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────
POSTGRES_USER=infinity
POSTGRES_PASSWORD=infinity_secret
POSTGRES_DB=infinity_cloud
DATABASE_URL=postgresql+asyncpg://infinity:infinity_secret@postgres:5432/infinity_cloud
DATABASE_URL_SYNC=postgresql://infinity:infinity_secret@postgres:5432/infinity_cloud

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── JWT ───────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Proxmox VE ───────────────────────────────────────
PROXMOX_HOST=https://proxmox.example.com:8006
PROXMOX_USER=root@pam
PROXMOX_TOKEN_NAME=infinity
PROXMOX_TOKEN_VALUE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_VERIFY_SSL=false

# ── Frontend ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Безопасность ──────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_PER_MINUTE=100

# ── Sentry (опционально) ─────────────────────────────
SENTRY_DSN=

# ── Администратор по умолчанию ────────────────────────
ADMIN_EMAIL=admin@infinity.cloud
ADMIN_PASSWORD=Admin123!
